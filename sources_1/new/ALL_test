module TOP(clk,reset,in,out,clksel);
  input clk,rst,clksel;
  input [3:0]in;
  output reg [3:0]out=4'b0000;

reg [3:0]reg_A = 4'b0000;
reg [3:0]reg_B = 4'b0000;  //register
reg [3:0]pcnt = 4'b0000;  //program count
reg Carry = 0;  //carry
reg [7:0]rom[0:15];

wire[7:0]temp;  //rom temp

wire [3:0]opec;  //opecode
wire [3:0]Im;
wire [3:0]ALU;
reg[3:0]i_chan;
wire Cpls;
wire clkt;

reg selectA,selectB,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel;
gen_1Hz gen_1Hz_inst(.clk(clk),.rst(rst),.clk_1Hz(clk_1Hz));
gen_10Hz gen_10Hz_inst(.clk(clk) ,. rst(rst),.clk_10Hz(clk_10Hz));

assign temp = rom[pcnt];
assign opec = temp[7:4];
assign Im = temp[3:0];
assign clkt = (clksel == 1'b1)?clk_10Hz : clk_1Hz;
//ROM
initial begin
rom[0]=8'b00100000;  //regA+IN
rom[1]=8'b10100000;  //regA out
rom[2]=8'b10000001;  //regA-1
rom[3]= 8'b10100000;  //regA out
rom[4]= 8'b10000001;  //regA-1
rom[5]=8'b10100000;  //regA out
rom[6] =8'b10000001;  //regA-1
rom[7]=8'b10100000;  //regA out
rom[8] =8'b10000001;  //regA-1
rom[9]= 8'b10100000;  //regA out
rom[10]=8'b10000001;  //regA-1
rom[11]=8'b10100000;  //regA out
rom[12]=8'b10000001;//regA-1
rom[13]=8'b10100000;//regA out
rom[14]=8'b10000001;//regA-1
rom[15] =8'b10100000;//regA out
end

//decoder
always@(*)
case(opec)
4'b0000 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b0001110;  //ADD A, Im
4'b0001 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b010111x;  //MOV A, B
4'b0010 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel) =7'b100111x;  //IN A
4'b0011 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b110111x;  //MOV A, Im
4'b0100 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel) =7'b001011x;  //MOV B, A
4'b0101: {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b0110110;  //ADD B, Im
4'b0110 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b101011x;  //IN B
4'b0111 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel =7'b111011x;  //MOV B, Im
4'b1000: {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b0001111;  //SUB A, Im
4'b1001 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel}=7'b011101x;  //OUT B
4'b1010 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b001101x;  //OUT A
4'b1011 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b111101x;  //OUT Im
4'b1101: {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b0110111;  //SUB B,Im
4'b1110:{selectB,selectA,LOAD0,LOADI,LOAD2,LOAD3,ALUsel]=Carry? 7bxx1111x: 7'b111110x;  //JNC Im
4'b1111 : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'b111110x;  //JMP Im
default : {selectB,selectA,LOAD0,LOAD1,LOAD2,LOAD3,ALUsel} =7'bxxxxxxx;
endcase

//selector
always@(*)
    case({selectB,selectA})
    2'b00 : i_chan = reg_A;
    2'b01 : i_chan = reg_B;
    2'b10 : i_chan = in;
    2'b11 : i_chan = 4'b0000;
    endcase

//ALU
assign {Cpls,ALU} = ALUsel?(i_chan - Im):(i_chan+Im);

//register
always@(posedge clkt or posedge rst)
if(rst)
  {reg_A,reg_B,out,pcnt,Carry} <= 0;
else begin
  if(~LOAD0) reg_A <= ALU;
  if(~LOAD1) reg_B <= ALU;
  if(~LOAD2) out <= ALU;
pcnt <=~ LOAD3? ALU : pcnt +1'b1;
Carry <= Cpls;

endmodule

//1Hz発生
module gen_1Hz(clk,rst,clk_1Hz);
input clk,rst;
output clk_1Hz;

reg[26:0]count;
reg clk_1Hz;
always@(posedge clk or posedge rst)begin
if(rst == 1'b1)begin
count <= 0;
clk_1Hz <= 0;
end else begin
count <= count + 1'bl;
if(count == 27'd25000000)begin
clk_1Hz <=~ clk_1Hz;
count <= 27'b0;

end

end

endmodule

//10Hz発生
module gen_10Hz(clk,rst,clk_10Hz);
input clk,rst;
output clk_10Hz;

reg[26:0]count;
reg clk_10Hz;
always@(posedge clk or posedge rst)begin
if(rst == 1'b1)begin
count <= 0;
clk_10Hz <= 0;
end else begin
count <= count + 1'bl;
if(count == 27'd25000000)begin
clk_10Hz <=~ clk_10Hz;
count <= 27'b0;

end

end

endmodule
##clk
set_property IOSTANDARD LVCMOS33 [get_ports clk]

end
